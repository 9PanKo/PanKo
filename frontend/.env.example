# Copy to .env locally. On Railway: set on the *frontend* service (Vite bakes these in at build time).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
# Public URL of your Railway *backend* service (no trailing slash)
VITE_API_URL=https://your-backend.up.railway.app
